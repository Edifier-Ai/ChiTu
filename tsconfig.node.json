{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "target": "ES2020",
    "lib": ["ES2020"]
  },
  "include": ["src/main/**/*.ts", "src/preload/**/*.ts"]
}

{
  "name": "chitu",
  "version": "0.0.32",
  "description": "赤兔数据采集系统 beta 版",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "nodemon --watch src/main --ext ts --exec \"sh -c 'tsc --project tsconfig.build.json && electron .'\"",
    "build": "tsc --project tsconfig.build.json && tsc --project tsconfig.json && vite build",
    "build:crawler": "node scripts/build-crawler.mjs",
    "package": "npm run build && npm run build:crawler && electron-builder --mac",
    "package:all": "npm run build && npm run build:crawler && electron-builder --mac --win --linux",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest run"
  },
  "keywords": [
    "crawler",
    "data-collection",
    "electron",
    "react"
  ],
  "author": "ChiTu Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/react-virtualized-auto-sizer": "^1.0.4",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "globals": "^14.0.0",
    "nodemon": "^3.0.3",
    "postcss": "^8.4.33",
    "prettier": "^3.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^7.0.0",
    "vite": "^5.0.11",
    "vite-plugin-electron": "^0.28.2",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "archiver": "^5.3.2",
    "electron-log": "^5.0.0"
  },
  "build": {
    "appId": "com.chitu.app",
    "productName": "赤兔数据采集系统",
    "icon": "icon.icns",
    "mac": {
      "category": "public.app-category.utilities",
      "target": "dmg",
      "icon": "icon.icns"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "dist_crawler/**/*",
      "icon.icns",
      "icon.png",
      "!**/.DS_Store"
    ],
    "asarUnpack": [
      "dist_crawler/**"
    ],
    "directories": {
      "output": "release"
    }
  }
}
